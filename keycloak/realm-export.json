{
    "id": "peleadores-realm",
    "realm": "peleadores-realm",
    "displayName": "Peleadores Realm",
    "enabled": true,
    "sslRequired": "none",
    "registrationAllowed": false,
    "loginWithEmailAllowed": true,
    "duplicateEmailsAllowed": false,
    "resetPasswordAllowed": true,
    "editUsernameAllowed": false,
    "bruteForceProtected": true,
    "roles": {
        "realm": [
            {
                "name": "ROLE_USER",
                "description": "Standard user role",
                "composite": false,
                "clientRole": false
            },
            {
                "name": "ROLE_ADMIN",
                "description": "Administrator role",
                "composite": false,
                "clientRole": false
            }
        ]
    },
    "clients": [
        {
            "clientId": "peleadores-frontend",
            "name": "Peleadores Frontend (Postman / Dev)",
            "enabled": true,
            "publicClient": true,
            "clientAuthenticatorType": "client-secret",
            "redirectUris": [
                "*"
            ],
            "webOrigins": [
                "*"
            ],
            "directAccessGrantsEnabled": true,
            "standardFlowEnabled": true,
            "implicitFlowEnabled": false,
            "serviceAccountsEnabled": false,
            "protocol": "openid-connect"
        }
    ],
    "users": [
        {
            "username": "testuser",
            "email": "testuser@example.com",
            "firstName": "Test",
            "lastName": "User",
            "enabled": true,
            "emailVerified": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "testuser",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "ROLE_USER"
            ]
        },
        {
            "username": "adminuser",
            "email": "admin@example.com",
            "firstName": "Admin",
            "lastName": "User",
            "enabled": true,
            "emailVerified": true,
            "credentials": [
                {
                    "type": "password",
                    "value": "adminuser",
                    "temporary": false
                }
            ],
            "realmRoles": [
                "ROLE_USER",
                "ROLE_ADMIN"
            ]
        }
    ]
}